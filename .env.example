# Base de datos PostgreSQL + PostGIS
DATABASE_URL=postgresql://delitos_user:delitos_pass@localhost:5432/delitos_tucuman

# Ruta base de shapefiles en unidad de red
SHAPES_BASE_PATH=Z:\MAPA DEL DELITO\MAPAS DEL DELITO POR JURISDICCIONES

# Encoding de los shapefiles
SHAPE_ENCODING=latin-1

# Ruta al archivo KML de jurisdicciones
KML_PATH=Z:\MAPA DEL DELITO\jurisdicciones.kml

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
